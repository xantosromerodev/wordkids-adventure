<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wordkids.controller.MenuController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: linear-gradient(to bottom, #4facfe, #00f2fe);">

    <Label text="WORDKIDS ADVENTURE"
           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <Button text="PLAY"
            fx:id="playButton"
            onAction="#handlePlay"
            style="-fx-font-size: 20px;-fx-background-color: #FFD93D;-fx-text-fill: black;-fx-background-radius: 10;-fx-padding: 10 30 10 30;"/>

    <Button text="Exit"
            fx:id="exitButton"
            onAction="#handleExit"
            style="-fx-font-size: 20px;-fx-background-color: #FF6B6B;-fx-text-fill: white;-fx-background-radius: 10;-fx-padding: 10 30 10 30;"/>

</VBox>
